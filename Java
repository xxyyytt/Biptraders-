body {
  font-family: Arial;
  background: #0f172a;
  color: white;
  margin: 0;
  text-align: center;
}

.container {
  padding: 20px;
}

.card {
  background: #1e293b;
  margin: 15px auto;
  padding: 20px;
  width: 90%;
  max-width: 400px;
  border-radius: 10px;
}

button {
  padding: 10px 20px;
  border: none;
  background: #22c55e;
  color: white;
  border-radius: 8px;
  cursor: pointer;
}
